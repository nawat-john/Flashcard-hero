# Copy this file to `.env` and fill in the values from your Supabase project
# (Project Settings → Data API). These are safe to expose in the client bundle:
# the anon key is protected by Row Level Security. `.env` is gitignored.
#
# The EXPO_PUBLIC_ prefix is required — Expo only inlines env vars with it.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
